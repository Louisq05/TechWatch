# Copie ce fichier en « .env » et renseigne tes valeurs.
# Le .env est ignoré par git : tes identifiants ne partent JAMAIS sur GitHub.
#
# Gmail : active la validation en 2 étapes sur ton compte Google, puis crée un
# « mot de passe d'application » sur https://myaccount.google.com/apppasswords
# et colle-le ci-dessous (16 lettres, sans espaces).

TECHWATCH_SMTP_HOST=smtp.gmail.com
TECHWATCH_SMTP_PORT=587
TECHWATCH_SMTP_USER=ton.adresse@gmail.com
TECHWATCH_SMTP_PASSWORD=mot_de_passe_application_16_lettres
TECHWATCH_MAIL_FROM=ton.adresse@gmail.com
TECHWATCH_MAIL_TO=ton.adresse@gmail.com
